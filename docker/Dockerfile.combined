# syntax=docker/dockerfile:1.7
# COMBINED cloud image = the spa-cloud stack (RFdiffusion3 + SPA + ESM3 + CLSS + atomworks + ProteinMPNN,
# in system python) PLUS OpenFold3/triton in an ISOLATED `spa-verify-of3` conda env. Mirrors the local
# machine (spa-dev + spa-verify-of3 as two envs) so the validation flywheel runs as ONE job/process,
# end-to-end: RFD3±SPA generate -> ProteinMPNN -> OF3 refold -> score. No two-stage GCS handoff.
#
# The OF3Refolder defaults to conda_env="spa-verify-of3" and shells `conda run -n spa-verify-of3
# run_openfold`, so the flywheel is UNCHANGED. OF3 stays in its own conda env -> its deps never re-solve
# against the SPA stack's ~160 pins (the reason isolation was needed; a 2nd env gives it without a 2nd image).
#
# Builds FROM the already-pushed spa-cloud image (so no SSH forwarding / private-dep re-clone needed here;
# OF3 is public). The OF3 recipe (torch 2.5.1+cu124 + openfold3 @ e583ecee + triton) is the one validated
# by docker/Dockerfile.of3 (the standalone of3-triton build). Build: docker/build_and_push_combined.sh.

FROM us-central1-docker.pkg.dev/spa-dev-499900/spa/spa-cloud:0.3.0

ENV DEBIAN_FRONTEND=noninteractive

# OF3 runtime system libs not in the slim spa-cloud base (rdkit/biotite want libGL/libXrender; kalign builds).
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential libgl1 libxrender1 libxext6 \
    && rm -rf /var/lib/apt/lists/*

# Miniconda (the SPA stack stays in system python; conda hosts only the isolated OF3 env).
RUN curl -fsSL https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -o /tmp/mc.sh \
    && bash /tmp/mc.sh -b -p /opt/conda && rm /tmp/mc.sh \
    && ln -s /opt/conda/bin/conda /usr/local/bin/conda

# The `spa-verify-of3` conda env: OF3 + triton (the validated recipe), isolated site-packages.
# -c conda-forge --override-channels avoids the Anaconda `defaults` channel (its ToS gate blocks a
# non-interactive `conda create`); also matches the local conda-forge/strict setup.
# Create WITH pip and install via `python -m pip` — otherwise `conda run ... pip` resolves to the base
# image's SYSTEM pip and installs into system-python, not this env (then the env has no torch).
RUN /opt/conda/bin/conda create -y -n spa-verify-of3 -c conda-forge --override-channels python=3.12 pip \
    && /opt/conda/bin/conda run -n spa-verify-of3 python -m pip install --no-cache-dir \
         torch==2.5.1 torchvision==0.20.1 torchaudio==2.5.1 --index-url https://download.pytorch.org/whl/cu124 \
    && /opt/conda/bin/conda run -n spa-verify-of3 python -m pip install --no-cache-dir \
         "openfold3 @ git+https://github.com/aqlaboratory/openfold-3.git@e583ecee" \
    && /opt/conda/bin/conda run -n spa-verify-of3 python -c \
         "import torch, triton, openfold3; print('of3 env OK', torch.__version__, '| triton', triton.__version__)" \
    && /opt/conda/bin/conda run -n spa-verify-of3 sh -c "command -v run_openfold"

# tmtools — TM-score (tmtools.tm_align) for the Stage-4 eval scoring (adherence TM + diversity TM).
# Goes in SYSTEM python: the flywheel + scoring run there; only the OF3 refold subprocess uses the conda
# env. Absent from the training base (never needed for training); build-essential above supplies its C ext.
RUN pip install --no-cache-dir tmtools \
    && python -c "import tmtools; print('tmtools OK')"

WORKDIR /workspace
CMD ["/bin/bash"]
