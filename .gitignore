# ─── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ─── Packaging / build artifacts ──────────────────────────────────────────
build/
dist/
wheels/
*.egg
*.egg-info/
.eggs/
pip-wheel-metadata/
.installed.cfg

# ─── Virtualenvs (conda envs live outside the repo; ignore any local ones) ──
.venv/
venv/
env/
ENV/

# ─── Hydra run outputs ────────────────────────────────────────────────────
# Hydra writes per-run dirs (outputs/, multirun/) and a .hydra/ snapshot.
outputs/
multirun/
.hydra/

# ─── Experiment tracking / logs ───────────────────────────────────────────
wandb/
mlruns/
lightning_logs/
tensorboard/
runs/
events.out.tfevents.*
*.log
logs/

# ─── Model checkpoints / weights (never committed — large; live in ../models)
checkpoints/
*.ckpt
*.pt
*.pth
*.safetensors
# Exception: published SPA adapter weights (adapter-only exports, ~90-130 MB each) — see models/README.md
!models/*.pt

# ─── Caches: ESM3 tensor cache, prompt cache, preprocessed data ────────────
# These are large and machine-local. Generated by scripts/, pulled from GCS,
# or symlinked in. Keep them out of git.
/cache/
/esm3_cache/
/prompt_cache/
*.npy
*.npz
*.h5
*.lmdb

# ─── Local data dirs / symlinks (point outside the repo to ../training_data)
# `data/`, `training_data/` are conventionally symlinks on a dev box.
/data/
/training_data/
/processed/
/train/
/validate/
/test/

# ─── Tool caches ──────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.coverage
htmlcov/

# ─── Secrets / local env (HF token, any API keys) — NEVER commit ──────────
.env
.env.*
!.env.example

# ─── Editor / OS ──────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~
.DS_Store
Thumbs.db
CLAUDE.md
